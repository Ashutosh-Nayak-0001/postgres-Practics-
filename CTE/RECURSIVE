======================CTE=======================================

WITH RECURSIVE numbers AS (
    SELECT 1 AS n   -- Anchor

    UNION ALL

    SELECT n + 1    -- Recursive
    FROM numbers
    WHERE n < 5
)
SELECT * FROM numbers;

WITH RECURSIVE emp_tree AS (
    
    -- Anchor (top-level manager)
    SELECT emp_id, name, manager_id
    FROM employees
    WHERE manager_id IS NULL

    UNION ALL

    -- Recursive part
    SELECT e.emp_id, e.name, e.manager_id
    FROM employees e
    JOIN emp_tree et 
    ON e.manager_id = et.emp_id
)
SELECT * FROM emp_tree;

WITH RECURSIVE emp_tree AS (
    
    SELECT emp_id, name, manager_id, 1 AS level
    FROM employees
    WHERE manager_id IS NULL

    UNION ALL

    SELECT e.emp_id, e.name, e.manager_id, et.level + 1
    FROM employees e
    JOIN emp_tree et 
    ON e.manager_id = et.emp_id
)
SELECT * FROM emp_tree;

WITH cte_name AS (
    SELECT ...
)
SELECT * FROM cte_name;

WITH RECURSIVE cte_name AS (

    -- Anchor query
    SELECT ...

    UNION ALL

    -- Recursive query (self-reference)
    SELECT ...
    FROM cte_name
    WHERE condition
)
SELECT * FROM cte_name;

| Feature        | CTE                | Recursive CTE                  |
| -------------- | ------------------ | ------------------------------ |
| Keyword        | `WITH`             | `WITH RECURSIVE`               |
| Self Reference | ❌ No               | ✅ Yes                          |
| Structure      | Single query       | Two parts (Anchor + Recursive) |
| UNION          | ❌ Not required     | ✅ Required (`UNION ALL`)       |
| Looping        | ❌ No               | ✅ Yes                          |
| Use Case       | Simple temp result | Hierarchy, tree, sequences     |


WITH emp AS (
    SELECT * FROM employees
)
SELECT * FROM emp;

WITH RECURSIVE nums AS (
    SELECT 1
    UNION ALL
    SELECT n + 1 FROM nums WHERE n < 5
)
SELECT * FROM nums;

===============
CTE = temporary table
👉 Recursive CTE = temporary table + loop
