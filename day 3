3->SELECT EXTRACT(YEAR FROM hire_date) AS hire_year,
       COUNT(emp_id) AS employee_count
FROM employees
GROUP BY hire_year
ORDER BY hire_year;

4->SELECT department,
       job_title,
       COUNT(emp_id) AS employee_count
FROM employees
GROUP BY department, job_title
ORDER BY department, job_title;

5->select count(emp_id), Extract(month from hire_date) as hire_month
from employees group by hire_month;

