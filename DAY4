SELECT STRING_AGG(first_name, ', ')
FROM employees;

SELECT department_id,
STRING_AGG(first_name, ', ')
FROM employees
GROUP BY department_id;

SELECT ARRAY_AGG(first_name)
FROM employees;

SELECT BOOL_AND(is_active)
FROM employees;

SELECT BOOL_OR(is_active)
FROM employees;

SELECT JSON_AGG(first_name)
FROM employees;

SELECT department_id, AVG(salary)
FROM employees
GROUP BY department_id
HAVING AVG(salary) > 20000;

select department , count(emp_id) from employees
group by department;

select department , avg(salary) from employees
group by department;

select department , avg(salary) from employees
group by department having avg(salary) > 50000


SELECT department_id, AVG(salary)
FROM employees
WHERE salary > 30000
GROUP BY department_id
HAVING AVG(salary) > 50000;

select department , count(emp_id) as emp_count
from employees group by department 
having count(emp_id) > 5

SELECT SUM(salary) AS total_salary
FROM employees
WHERE hire_date > '2021-12-31';

SELECT EXTRACT(YEAR FROM hire_date)
FROM employees;

SELECT EXTRACT(MONTH FROM hire_date)
FROM employees;

SELECT EXTRACT(DAY FROM hire_date)
FROM employees;

SELECT CURRENT_DATE + INTERVAL '5 days';

SELECT CURRENT_DATE - INTERVAL '2 days';

SELECT name, AGE(hire_date)
FROM employees;

SELECT TO_CHAR(CURRENT_DATE, 'DD-MM-YYYY');

SELECT *
FROM employees
WHERE hire_date >= CURRENT_DATE - INTERVAL '30 days';

SELECT *
FROM employees
WHERE EXTRACT(YEAR FROM hire_date) = EXTRACT(YEAR FROM CURRENT_DATE);

select department , avg(salary) from employees
group by department having department = 'HR';

select department , sum(salary) as total from employees
group by department order by total desc limit  2

select DEPARTMENT, STRING_AGG(FIRST_NAME,',') FROM EMPLOYEES 
GROUP BY DEPARTMENT

select DEPARTMENT, ARRAY_AGG(FIRST_NAME) FROM EMPLOYEES 
GROUP BY DEPARTMENT

SELECT MAX(salary) - MIN(salary) AS salary_difference
FROM employees;

SELECT DEPARTMENT , SUM(SALARY)  FROM EMPLOYEES
GROUP BY DEPARTMENT HAVING SUM(SALARY) > 100000

SELECT COUNT(*) AS employees_above_avg
FROM employees
WHERE salary > (
    SELECT AVG(salary)
    FROM employees
);

SELECT  DEPARTMENT, COUNT(EMP_ID) , AVG(SALARY) FROM
EMPLOYEES GROUP BY DEPARTMENT 
HAVING COUNT(EMP_ID) > 3 AND AVG(SALARY) > 10000

SELECT D.DEPARTMENT_NAME , COUNT(E.EMP_ID) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME;

SELECT D.DEPARTMENT_NAME , SUM(E.SALARY) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME;


SELECT D.DEPARTMENT_NAME , AVG(E.SALARY) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME;

SELECT D.DEPARTMENT_NAME , SUM(E.SALARY) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME ORDER BY SUM(E.SALARY)
DESC LIMIT 1;

SELECT D.DEPARTMENT_NAME , COUNT(E.EMP_ID) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME HAVING COUNT(E.EMP_ID) >5

SELECT D.DEPARTMENT_NAME , MAX(E.SALARY) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME 

SELECT D.DEPARTMENT_NAME , COUNT(EMP_ID),
AVG(E.SALARY) FROM 
EMPLOYEES E 
JOIN 
DEPARTMNET D ON E.DEPARTMENT_ID = E.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME 

SELECT d.department_name, COUNT(e.emp_id)
FROM departments d
LEFT JOIN employees e
ON d.department_id = e.department_id
GROUP BY d.department_name;

